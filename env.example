# ─── Bot ──────────────────────────────────────────────
# BotFather dan olingan token
BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ─────────────────────────────────────────
# Railway PostgreSQL plugin qo'shilganda avtomatik to'ldiriladi
# Lokal ishlatish uchun:
DATABASE_URL=postgresql+asyncpg://erp_user:erp_password@localhost:5432/telegram_erp

# ─── Redis ────────────────────────────────────────────
# Railway Redis plugin qo'shilganda avtomatik to'ldiriladi
# Lokal ishlatish uchun:
REDIS_URL=redis://localhost:6379/0

# ─── Admin ────────────────────────────────────────────
# Vergul bilan ajratilgan admin Telegram ID lari
ADMIN_IDS=123456789,987654321
